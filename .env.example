FLASK_APP=api.app_ofertas
FLASK_ENV=development
PORT=3010
SESSION_SECRET=change-me
SESSION_COOKIE_NAME=ofertas_session

# Database (you can use either DB_* or SQL_* aliases)
DB_SERVER=EMEBIDWH
DB_DATABASE=Digitalizacion
DB_USER=sa
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
SQL_SERVER=
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
SQL_DRIVER=

# Outlook / Microsoft Graph
# App-only mode for automatic service emails:
# - set AZURE_AUTH_MODE=app-only
# - set AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_TENANT_ID / OUTLOOK_MAILBOX
# - AZURE_REDIRECT_URI can stay present; auth mode is forced by AZURE_AUTH_MODE
# Delegated mode with user sign-in:
# - set AZURE_AUTH_MODE=delegated
# - set AZURE_CLIENT_ID / AZURE_CLIENT_SECRET / AZURE_TENANT_ID / AZURE_REDIRECT_URI
# - local callback example: https://localhost:3010/auth/callback
# - production callback example: https://192.168.253.9:3010/auth/callback
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=
OUTLOOK_MAILBOX=
OUTLOOK_MAILBOX_MATCH=

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_AUTH_MODE=
AZURE_REDIRECT_URI=
AZURE_AUTHORITY=
